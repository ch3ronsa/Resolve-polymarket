generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResolutionRisk {
  LOW
  MEDIUM
  HIGH
}

model MarketAnalysis {
  id               String         @id @default(cuid())
  slug             String         @unique
  marketId         String
  question         String
  summary          String
  resolutionSource String?
  riskLabel        ResolutionRisk
  ambiguityFlags   Json
  criticalDates    Json
  rawMarket        Json
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  lastAnalyzedAt   DateTime       @default(now())
}

